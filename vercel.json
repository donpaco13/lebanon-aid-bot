{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/cron/scrape.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "0 8 * * *"
    }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" }
  ]
}
