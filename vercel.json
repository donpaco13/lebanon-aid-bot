{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 30
    },
    "api/cron/scrape.js": {
      "maxDuration": 300
    }
  },
  "routes": [
    { "src": "/api/health", "dest": "/api/health.js" }
  ],
  "crons": [
    { "path": "/api/cron/scrape", "schedule": "*/30 * * * *" }
  ]
}
